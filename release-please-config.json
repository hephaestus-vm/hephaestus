{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "hephaestus",
      "version-file": "version.txt",
      "changelog-path": "CHANGELOG.md",
      "versioning": "prerelease",
      "prerelease": true,
      "prerelease-type": "alpha",
      "include-v-in-tag": true,
      "include-component-in-tag": false,
      "pull-request-title-pattern": "chore${scope}: release${component} ${version}",
      "extra-files": [
        {
          "type": "toml",
          "path": "src/hephaestus-cli/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "src/hephaestus-firecracker/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "src/hephaestus-jailer/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name == 'hephaestus-cli' || @.name == 'hephaestus-firecracker' || @.name == 'hephaestus-jailer')].version"
        }
      ]
    }
  }
}
